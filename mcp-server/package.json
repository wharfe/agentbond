{
  "name": "@agentbond/mcp-server",
  "version": "0.1.2",
  "description": "MCP server for agentbond — AI agent authorization and governance",
  "license": "MIT",
  "author": "agentbond contributors",
  "keywords": ["ai-agents", "mcp", "mcp-server", "authorization", "agentbond"],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "agentbond-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wharfe/agentbond.git",
    "directory": "mcp-server"
  },
  "homepage": "https://github.com/wharfe/agentbond/tree/main/mcp-server",
  "bugs": {
    "url": "https://github.com/wharfe/agentbond/issues"
  },
  "dependencies": {
    "@agentbond/core": "workspace:*",
    "@agentbond/auth": "workspace:*",
    "@agentbond/intent": "workspace:*",
    "@agentbond/contract": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.24.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run"
  }
}
